  call gr_ensureValidNeighborInfo(10)

! raytracing is not really dependent on rest of the particle data structure
! allocate memory for local rays, plus buffers for communication 

  call pt_initRays()
! generate new rays from sources
! this happens every hydro half time step
! face sources here
  call pt_generateRaysFace(dt)

! pointy sources here
  call pt_generateRaysPoint(dt)

! calls init routines for async communication, otherwise stub
  call pt_startComm()

! actual raytracing
  call pt_advanceRaysFace(dt)

! "advanced"
  call pt_advanceRaysPoint(dt)

! clean memory, spring fresh
  call pt_finalizeRays()
  return
end subroutine Particles_rayAdvance
