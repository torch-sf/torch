REQUIRES physics/Hydro
REQUIRES physics/Eos/EosMain/Gamma  # should we use Multigamma?...
#REQUIRES Particles/ParticlesMain/active/SinkNoAdvance

# If FERVENT is omitted, Multispecies is not actually needed.
# Easier to leave as "required", code should still work, but Multispecies will
# contain nothing.
REQUIRES Multispecies

REQUIRES Grid/GridMain/paramesh  # for nested refinement

REQUESTS physics/sourceTerms/Heat/HeatMain/HeatCool/phenHeat  # for abundM, metal information...

# ??? 2019 Feb 21 AT don't know what this is for . . .
