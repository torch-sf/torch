# Stirred (driven) turbulence
# ---------------------------
#REQUIRES physics/sourceTerms/Stir/StirMain/Generate
LINKIF st_calcAccel.F90                                     physics/sourceTerms/Stir/StirMain/FromFile

D sim_stirLayer         Focus the stirring to thin layer in z,
D &                     defined by +/-sim_stirH
PARAMETER sim_stirLayer BOOLEAN     True

D sim_stirH             Scale height for turbulent stirring
D &                     z-profile scaling is 1 + tanh((h-|z|)/(0.5*h))
D &                     so that energy input is about the same
D &                     as constant forcing over +/-2h
PARAMETER sim_stirH     REAL        3.09E20 # 100 pc
