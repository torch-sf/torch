# Configuration file for the unit test of the BHTree Poisson Solver

REQUIRES Driver
REQUIRES physics/Hydro
REQUIRES physics/Eos/EosMain/Gamma
#REQUIRES physics/Eos/EosMain/Multigamma
#REQUIRES Particles/ParticlesMain/active/Sink/Couple_AMUSE
REQUIRES Multispecies

#REQUIRES physics/sourceTerms/Wind/WindMain
#REQUIRES physics/TreeRay/TreeRayMain/OnTheSpot

# file from which radial profiles of grid quantities are read
PARAMETER sim_cubeFile  STRING  "cube"


USESETUPVARS bhtreeAcc
IF bhtreeAcc
ELSE
VARIABLE GACX
VARIABLE GACY
VARIABLE GACZ
ENDIF

# Initial mag field

PARAMETER bx0 REAL 0.0
PARAMETER by0 REAL 0.0
PARAMETER bz0 REAL 0.0

# For radiation

# average molecular weights, if negative, calculated from chemistry data
PARAMETER sim_A_n      REAL    -1.0
PARAMETER sim_A_i      REAL    -1.0

PARAMETER sim_init_Hp  REAL    1.E-3

PARAMETER sim_gamma_n  REAL    1.66667
PARAMETER sim_gamma_i  REAL    1.66667

PARAMETER sim_tdust     REAL    18.0

# New Heating and Cooling routines
#D	sim_Z					gas metallicity in fractions of Solar metallicity. used in the heating routine			
#D	sim_G0					Interstellar radiation field in fractions of the Draine's field (which is 1.7 Habing's field.)	
#D	h_cr					Scale height of the cosmic ray heating.	2 kpc default
#D	use_constant_heating	Swith to use the old, constant heating routine 
#PARAMETER	sim_Z					REAL	1.0 
#PARAMETER	sim_G0					REAL	1.0
#PARAMETER	h_cr					REAL	6.1712e21
#PARAMETER	use_constant_heating	BOOLEAN	FALSE

# VorAMR Parameters
PARAMETER use_voramr        BOOLEAN False
PARAMETER voramr_source     STRING  "snapshot.hdf5"
PARAMETER voramr_input      STRING  "voramr_input.hdf5"
PARAMETER use_localRef      BOOLEAN False
PARAMETER center_localRef   BOOLEAN False
PARAMETER localRef_x        REAL    0.0
PARAMETER localRef_y        REAL    0.0
PARAMETER localRef_z        REAL    0.0
PARAMETER localRef_r        REAL    0.0
PARAMETER refine_on_particle_count BOOLEAN False
# Derefinement outside rectangular region of interest
PARAMETER use_deref         BOOLEAN False
PARAMETER deref_lref        INTEGER 1
PARAMETER deref_xl          REAL    0.0
PARAMETER deref_xr          REAL    0.0
PARAMETER deref_yl          REAL    0.0
PARAMETER deref_yr          REAL    0.0
PARAMETER deref_zl          REAL    0.0
PARAMETER deref_zr          REAL    0.0


# Static potential parameters
PARAMETER sim_aParm1        REAL 0.0
PARAMETER sim_aParm2        REAL 0.0
PARAMETER sim_aParm3        REAL 0.0
PARAMETER sim_aParm4        REAL 0.0
PARAMETER sim_withStaticGrav    BOOLEAN     False

#### Include passive scalars to track enrichment
USESETUPVARS withElements
IF withElements
# Flag telling FLASH to include element tracers. 
PPDEFINE TRACER_FIELDS
# Number of elements
PARAMETER sim_nelements INTEGER 9

# Tracer fields as mass scalars.
MASS_SCALAR E001
MASS_SCALAR E002
MASS_SCALAR E003
MASS_SCALAR E004
MASS_SCALAR E005
MASS_SCALAR E006
MASS_SCALAR E007
MASS_SCALAR E008
MASS_SCALAR E009

# Equvalent to tracer fields but for particles.
PARTICLEPROP E001 REAL
PARTICLEPROP E002 REAL
PARTICLEPROP E003 REAL
PARTICLEPROP E004 REAL
PARTICLEPROP E005 REAL
PARTICLEPROP E006 REAL
PARTICLEPROP E007 REAL
PARTICLEPROP E008 REAL
PARTICLEPROP E009 REAL

# Yields (mass/time) to be injected with feedback.
PARTICLEPROP Y001 REAL
PARTICLEPROP Y002 REAL
PARTICLEPROP Y003 REAL
PARTICLEPROP Y004 REAL
PARTICLEPROP Y005 REAL
PARTICLEPROP Y006 REAL
PARTICLEPROP Y007 REAL
PARTICLEPROP Y008 REAL
PARTICLEPROP Y009 REAL
ENDIF
