#Configuration file for testing Particles based refinement

REQUIRES Driver
REQUIRES RuntimeParameters
REQUIRES Grid/GridMain/paramesh


#Active particles.
PARTICLETYPE ACTIVE INITMETHOD custom MAPMETHOD weighted ADVMETHOD PT_ADVMETH_NONE
PARTICLETYPE NONEXISTENT INITMETHOD custom MAPMETHOD weighted ADVMETHOD PT_ADVMETH_NONE
PARTICLEPROP mass     REAL
D PARTICLEPROP momx     REAL
D PARTICLEPROP momy     REAL
D PARTICLEPROP momz     REAL
