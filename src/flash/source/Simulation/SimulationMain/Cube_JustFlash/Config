# Configuration file for the unit test of the BHTree Poisson Solver

REQUIRES Driver
REQUIRES physics/Hydro
REQUIRES physics/Eos/EosMain/Gamma
#REQUIRES physics/Eos/EosMain/Multigamma
#REQUIRES physics/sourceTerms/Heat/phenHeat/IGWCurve
#REQUIRES Particles/ParticlesMain/active/SinkNoAdvance
REQUIRES Multispecies


#REQUIRES physics/sourceTerms/Wind/WindMain
#REQUIRES physics/TreeRay/TreeRayMain/OnTheSpot

# file from which radial profiles of grid quantities are read
PARAMETER sim_cubeFile  STRING  "cube"

# Jeans refinement and derefinement criteria
# gives number of cells accross the Jeans length to refine/derefine
D jeans_ref             Jeans refinement criterion.
D & Gives number of cells accross the Jeans length to refine.
D jeans_deref           Jeans derefinement criterion.
D & Gives number of cells accross the Jeans length to derefine.
PARAMETER jeans_ref             REAL    32.0
PARAMETER jeans_deref           REAL    64.0


USESETUPVARS bhtreeAcc
IF bhtreeAcc
ELSE
VARIABLE GACX
VARIABLE GACY
VARIABLE GACZ
ENDIF

GUARDCELLS 6

# Variables that I added

VARIABLE TDUS
SPECIES IHP
SPECIES IHA

# Initial mag field

PARAMETER bx0 REAL 0.0
PARAMETER by0 REAL 0.0
PARAMETER bz0 REAL 0.0

# For radiation

# average molecular weights, if negative, calculated from chemistry data
PARAMETER sim_A_n      REAL    -1.0
PARAMETER sim_A_i      REAL    -1.0

PARAMETER sim_init_Hp  REAL    1.E-3

PARAMETER sim_gamma_n  REAL    1.66667
PARAMETER sim_gamma_i  REAL    1.66667

# effective temperature of the star
PARAMETER sim_Eph REAL 0.0 #1.0
PARAMETER sim_Nph REAL 0.0 #5e45

PARAMETER amNumDens     REAL    0.
PARAMETER amTemp        REAL    0.

PARAMETER sim_tdust     REAL    18.0

# New Heating and Cooling routines
D	sim_Z					gas metallicity in fractions of Solar metallicity. used in the heating routine			
D	sim_G0					Interstellar radiation field in fractions of the Draine's field (which is 1.7 Habing's field.)	
D	h_cr					Scale height of the cosmic ray heating.	2 kpc default
D	use_constant_heating	Swith to use the old, constant heating routine 

#PARAMETER	sim_Z					REAL	1.0 
#PARAMETER	sim_G0					REAL	1.0
#PARAMETER	h_cr					REAL	6.1712e21
